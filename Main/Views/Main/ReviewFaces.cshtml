@model Svema.Controllers.MainController.FaceReviewViewModel
@{
    Layout = "_Layout";
}

<div class="container p-5">
    <h2>Review Faces</h2>

    <h3>Unconfirmed Faces (@Model.UnconfirmedTotalCount total)</h3>
    <div class="row" id="unconfirmed-faces">
        @foreach (var face in Model.Unconfirmed)
        {
            <div class="col-md-3 mb-4 face-card" id="face-@face.FaceDetectionId">
                <div class="card">
                    <img src="/face/thumbnail/@face.FaceDetectionId" class="card-img-top"
                        style="height: 150px; object-fit: cover;">
                    <div class="card-body">
                        <p class="small text-muted mb-1">ID: @face.FaceDetectionId</p>
                        <a href="/view_shot?id=@face.ShotId&highlightFace=@face.FaceDetectionId" class="btn btn-sm btn-outline-secondary mb-2 w-100" target="_blank">View Shot</a>
                        <p>Assigned to: <strong>@face.Person?.FirstName @face.Person?.LastName</strong></p>
                        <button class="btn btn-success btn-sm w-100 mb-2"
                            onclick="confirmFace(@face.FaceDetectionId)">Confirm</button>

                        <select class="form-select form-select-sm mb-2" id="reassign-select-@face.FaceDetectionId">
                            <option value="">Reassign to...</option>
                            @foreach (var p in Model.Persons)
                            {
                                <option value="@p.PersonId">@p.FirstName @p.LastName</option>
                            }
                        </select>
                        <button class="btn btn-warning btn-sm w-100 mb-2"
                            onclick="reassignFace(@face.FaceDetectionId)">Reassign</button>

                        <button class="btn btn-danger btn-sm w-100"
                            onclick="notAFace(@face.FaceDetectionId)">Not a Face</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.UnconfirmedTotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center flex-wrap">
                @if (Model.UnconfirmedCurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/review?unconfirmedPage=@(Model.UnconfirmedCurrentPage - 1)&unassignedPage=@Model.UnassignedCurrentPage&pageSize=@Model.PageSize">Previous</a>
                    </li>
                }

                @{
                    var startPage = Math.Max(1, Model.UnconfirmedCurrentPage - 2);
                    var endPage = Math.Min(Model.UnconfirmedTotalPages, Model.UnconfirmedCurrentPage + 2);

                    // Always show first page
                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/faces/review?unconfirmedPage=1&unassignedPage=@Model.UnassignedCurrentPage&pageSize=@Model.PageSize">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    // Show pages around current
                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.UnconfirmedCurrentPage ? "active" : "")">
                            <a class="page-link" href="/faces/review?unconfirmedPage=@i&unassignedPage=@Model.UnassignedCurrentPage&pageSize=@Model.PageSize">@i</a>
                        </li>
                    }

                    // Always show last page
                    if (endPage < Model.UnconfirmedTotalPages)
                    {
                        if (endPage < Model.UnconfirmedTotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedTotalPages&unassignedPage=@Model.UnassignedCurrentPage&pageSize=@Model.PageSize">@Model.UnconfirmedTotalPages</a>
                        </li>
                    }
                }

                @if (Model.UnconfirmedCurrentPage < Model.UnconfirmedTotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/review?unconfirmedPage=@(Model.UnconfirmedCurrentPage + 1)&unassignedPage=@Model.UnassignedCurrentPage&pageSize=@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <h3>Unassigned Faces (@Model.UnassignedTotalCount total)</h3>
    <div class="row" id="unassigned-faces">
        @foreach (var face in Model.Unassigned)
        {
            <div class="col-md-3 mb-4 face-card" id="face-@face.FaceDetectionId">
                <div class="card">
                    <img src="/face/thumbnail/@face.FaceDetectionId" class="card-img-top"
                        style="height: 150px; object-fit: cover;">
                    <div class="card-body">
                        <p class="small text-muted mb-1">ID: @face.FaceDetectionId</p>
                        <a href="/view_shot?id=@face.ShotId&highlightFace=@face.FaceDetectionId" class="btn btn-sm btn-outline-secondary mb-2 w-100" target="_blank">View Shot</a>
                        <p>Unknown Person</p>
                        <select class="form-select form-select-sm mb-2" id="assign-select-@face.FaceDetectionId">
                            <option value="">Assign to...</option>
                            @foreach (var p in Model.Persons)
                            {
                                <option value="@p.PersonId">@p.FirstName @p.LastName</option>
                            }
                        </select>
                        <button class="btn btn-primary btn-sm w-100 mb-2"
                            onclick="assignFace(@face.FaceDetectionId)">Assign</button>

                        <button class="btn btn-danger btn-sm w-100 mb-2"
                            onclick="notAFace(@face.FaceDetectionId)">Not a Face</button>

                        <hr />
                        <input type="text" class="form-control form-control-sm mb-2" placeholder="New Person Name"
                            id="new-person-name-@face.FaceDetectionId">
                        <button class="btn btn-outline-primary btn-sm w-100"
                            onclick="createAndAssign(@face.FaceDetectionId)">Create & Assign</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.UnassignedTotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center flex-wrap">
                @if (Model.UnassignedCurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedCurrentPage&unassignedPage=@(Model.UnassignedCurrentPage - 1)&pageSize=@Model.PageSize">Previous</a>
                    </li>
                }

                @{
                    var startPageUnassigned = Math.Max(1, Model.UnassignedCurrentPage - 2);
                    var endPageUnassigned = Math.Min(Model.UnassignedTotalPages, Model.UnassignedCurrentPage + 2);

                    // Always show first page
                    if (startPageUnassigned > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedCurrentPage&unassignedPage=1&pageSize=@Model.PageSize">1</a>
                        </li>
                        if (startPageUnassigned > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    // Show pages around current
                    for (int i = startPageUnassigned; i <= endPageUnassigned; i++)
                    {
                        <li class="page-item @(i == Model.UnassignedCurrentPage ? "active" : "")">
                            <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedCurrentPage&unassignedPage=@i&pageSize=@Model.PageSize">@i</a>
                        </li>
                    }

                    // Always show last page
                    if (endPageUnassigned < Model.UnassignedTotalPages)
                    {
                        if (endPageUnassigned < Model.UnassignedTotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedCurrentPage&unassignedPage=@Model.UnassignedTotalPages&pageSize=@Model.PageSize">@Model.UnassignedTotalPages</a>
                        </li>
                    }
                }

                @if (Model.UnassignedCurrentPage < Model.UnassignedTotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/review?unconfirmedPage=@Model.UnconfirmedCurrentPage&unassignedPage=@(Model.UnassignedCurrentPage + 1)&pageSize=@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<script>
    async function confirmFace(faceId) {
        const response = await fetch(`/api/faces/confirm/${faceId}`, { method: 'POST' });
        if (response.ok) {
            document.getElementById(`face-${faceId}`).remove();
        } else {
            alert('Failed to confirm face');
        }
    }

    async function reassignFace(faceId) {
        const select = document.getElementById(`reassign-select-${faceId}`);
        const personId = select.value;
        if (!personId) return;

        const response = await fetch(`/api/faces/reassign/${faceId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parseInt(personId))
        });

        if (response.ok) {
            document.getElementById(`face-${faceId}`).remove();
        } else {
            alert('Failed to reassign face');
        }
    }

    async function assignFace(faceId) {
        const select = document.getElementById(`assign-select-${faceId}`);
        const personId = select.value;
        if (!personId) return;

        const response = await fetch(`/api/faces/reassign/${faceId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parseInt(personId))
        });

        if (response.ok) {
            document.getElementById(`face-${faceId}`).remove();
        } else {
            alert('Failed to assign face');
        }
    }

    async function createAndAssign(faceId) {
        const nameInput = document.getElementById(`new-person-name-${faceId}`);
        const fullName = nameInput.value.trim();
        if (!fullName) return;

        const parts = fullName.split(' ');
        const firstName = parts[0];
        const lastName = parts.slice(1).join(' ') || '';

        // Create person
        const createResponse = await fetch('/api/persons', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ firstName, lastName })
        });

        if (!createResponse.ok) {
            alert('Failed to create person');
            return;
        }

        const person = await createResponse.json();

        // Assign face
        const assignResponse = await fetch(`/api/faces/reassign/${faceId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(person.personId)
        });

        if (assignResponse.ok) {
            document.getElementById(`face-${faceId}`).remove();
            // Optionally reload page to update dropdowns with new person
            location.reload();
        } else {
            alert('Failed to assign face to new person');
        }
    }

    async function notAFace(faceId) {
        if (!confirm('Are you sure this is not a face? This will permanently delete it.')) {
            return;
        }

        const response = await fetch(`/api/faces/delete/${faceId}`, {
            method: 'POST'
        });

        if (response.ok) {
            document.getElementById(`face-${faceId}`).remove();
        } else {
            alert('Failed to delete face');
        }
    }
</script>
