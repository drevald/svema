@model Svema.Controllers.MainController.FaceListViewModel
@{
    Layout = "_Layout";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Unassigned Faces (@Model.TotalCount total)</h2>
        <div>
            <a href="/faces/unconfirmed" class="btn btn-outline-primary">Unconfirmed Faces</a>
        </div>
    </div>

    <!-- Batch Actions Toolbar -->
    <div class="card mb-3" id="batch-toolbar" style="display: none;">
        <div class="card-body d-flex align-items-center gap-3 flex-wrap">
            <span class="fw-bold"><span id="selected-count">0</span> selected</span>
            <div class="d-flex align-items-center gap-2">
                <select class="form-select form-select-sm" id="batch-assign-select" style="width: 200px;">
                    <option value="">Assign to...</option>
                    @foreach (var p in Model.Persons.OrderBy(p => p.FirstName).ThenBy(p => p.LastName))
                    {
                        <option value="@p.PersonId">@p.FirstName @p.LastName</option>
                    }
                </select>
                <button class="btn btn-primary btn-sm" onclick="batchAssign()">Assign</button>
            </div>
            <div class="d-flex align-items-center gap-2">
                <input type="text" class="form-control form-control-sm" id="batch-new-person-name"
                       placeholder="New Person Name" style="width: 200px;">
                <button class="btn btn-outline-primary btn-sm" onclick="batchCreateAndAssign()">Create & Assign</button>
            </div>
            <button class="btn btn-danger btn-sm" onclick="batchDelete()">Delete Selected</button>
            <button class="btn btn-secondary btn-sm" onclick="batchNoFaces()">No Faces (Exclude Shots)</button>
            <button class="btn btn-outline-secondary btn-sm" onclick="clearSelection()">Clear Selection</button>
        </div>
    </div>

    <div class="d-flex flex-wrap" id="faces-grid">
        @foreach (var face in Model.Faces)
        {
            <div class="face-card" data-face-id="@face.FaceDetectionId" data-shot-id="@face.ShotId">
                <div class="card text-bg-secondary mb-5 me-5 shadow position-relative" style="width: 16rem; height: 16rem;">
                    <div class="position-absolute top-0 start-0 p-2" style="z-index: 10;">
                        <input type="checkbox" class="form-check-input face-checkbox shadow"
                               data-face-id="@face.FaceDetectionId"
                               data-shot-id="@face.ShotId"
                               style="width: 1.85rem; height: 1.85rem; cursor: pointer;">
                    </div>
                    <div class="card-body p-0" style="cursor: pointer; background-image: url('/face/thumbnail/@face.FaceDetectionId'); background-size: cover; background-position: center;"
                         onclick="toggleCheckbox(@face.FaceDetectionId, event)">
                    </div>
                    <div class="card-footer p-2">
                        <div class="btn-group btn-group-sm w-100 mb-1">
                            <a href="/view_shot?id=@face.ShotId" class="btn btn-outline-light btn-sm" target="_blank" title="View">
                                <i class="bi bi-image"></i>
                            </a>
                            <button class="btn btn-danger btn-sm" onclick="notAFace(@face.FaceDetectionId)" title="Delete">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <select class="form-select form-select-sm mb-1" id="assign-select-@face.FaceDetectionId">
                            <option value="">Assign to...</option>
                            @foreach (var p in Model.Persons.OrderBy(p => p.FirstName).ThenBy(p => p.LastName))
                            {
                                <option value="@p.PersonId">@p.FirstName @p.LastName</option>
                            }
                        </select>
                        <button class="btn btn-primary btn-sm w-100" onclick="assignFace(@face.FaceDetectionId)">Assign</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center flex-wrap">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/unassigned?page=@(Model.CurrentPage - 1)&pageSize=@Model.PageSize">Previous</a>
                    </li>
                }

                @{
                    var startPage = Math.Max(1, Model.CurrentPage - 2);
                    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);

                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/faces/unassigned?page=1&pageSize=@Model.PageSize">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/faces/unassigned?page=@i&pageSize=@Model.PageSize">@i</a>
                        </li>
                    }

                    if (endPage < Model.TotalPages)
                    {
                        if (endPage < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="/faces/unassigned?page=@Model.TotalPages&pageSize=@Model.PageSize">@Model.TotalPages</a>
                        </li>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="/faces/unassigned?page=@(Model.CurrentPage + 1)&pageSize=@Model.PageSize">Next</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<script>
    let lastCheckedIndex = null;
    const checkboxes = document.querySelectorAll('.face-checkbox');

    // Shift+click range selection
    checkboxes.forEach((checkbox, index) => {
        checkbox.addEventListener('click', function(e) {
            if (e.shiftKey && lastCheckedIndex !== null) {
                const start = Math.min(lastCheckedIndex, index);
                const end = Math.max(lastCheckedIndex, index);
                const shouldCheck = this.checked;

                for (let i = start; i <= end; i++) {
                    checkboxes[i].checked = shouldCheck;
                }
            }
            lastCheckedIndex = index;
            updateToolbar();
        });
    });

    function toggleCheckbox(faceId, event) {
        if (event.target.tagName === 'INPUT') return;

        const checkbox = document.querySelector(`.face-checkbox[data-face-id="${faceId}"]`);
        const index = Array.from(checkboxes).indexOf(checkbox);

        if (event.shiftKey && lastCheckedIndex !== null) {
            const start = Math.min(lastCheckedIndex, index);
            const end = Math.max(lastCheckedIndex, index);
            const shouldCheck = !checkbox.checked;

            for (let i = start; i <= end; i++) {
                checkboxes[i].checked = shouldCheck;
            }
        } else {
            checkbox.checked = !checkbox.checked;
        }

        lastCheckedIndex = index;
        updateToolbar();
    }

    function updateToolbar() {
        const selected = document.querySelectorAll('.face-checkbox:checked');
        const toolbar = document.getElementById('batch-toolbar');
        const countSpan = document.getElementById('selected-count');

        if (selected.length > 0) {
            toolbar.style.display = 'block';
            countSpan.textContent = selected.length;
        } else {
            toolbar.style.display = 'none';
        }
    }

    function getSelectedIds() {
        return Array.from(document.querySelectorAll('.face-checkbox:checked'))
            .map(cb => parseInt(cb.dataset.faceId));
    }

    function clearSelection() {
        checkboxes.forEach(cb => cb.checked = false);
        updateToolbar();
    }

    async function batchAssign() {
        const ids = getSelectedIds();
        const personId = document.getElementById('batch-assign-select').value;

        if (ids.length === 0 || !personId) return;
        if (!confirm(`Assign ${ids.length} face(s)?`)) return;

        const response = await fetch('/api/faces/reassign-batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ faceIds: ids, personId: parseInt(personId) })
        });

        if (response.ok) {
            ids.forEach(id => document.querySelector(`[data-face-id="${id}"]`).remove());
            updateToolbar();
        } else {
            alert('Failed to assign faces');
        }
    }

    async function batchCreateAndAssign() {
        const ids = getSelectedIds();
        const fullName = document.getElementById('batch-new-person-name').value.trim();

        if (ids.length === 0 || !fullName) return;
        if (!confirm(`Create person "${fullName}" and assign ${ids.length} face(s)?`)) return;

        const parts = fullName.split(' ');
        const firstName = parts[0];
        const lastName = parts.slice(1).join(' ') || '';

        // Create person
        const createResponse = await fetch('/api/persons', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ firstName, lastName })
        });

        if (!createResponse.ok) {
            alert('Failed to create person');
            return;
        }

        const person = await createResponse.json();

        // Assign faces
        const assignResponse = await fetch('/api/faces/reassign-batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ faceIds: ids, personId: person.personId })
        });

        if (assignResponse.ok) {
            ids.forEach(id => document.querySelector(`[data-face-id="${id}"]`).remove());
            updateToolbar();
            document.getElementById('batch-new-person-name').value = '';
            // Reload to update dropdowns
            location.reload();
        } else {
            alert('Failed to assign faces to new person');
        }
    }

    async function batchDelete() {
        const ids = getSelectedIds();
        if (ids.length === 0) return;

        if (!confirm(`Delete ${ids.length} face(s)? This cannot be undone.`)) return;

        const response = await fetch('/api/faces/delete-batch', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(ids)
        });

        if (response.ok) {
            ids.forEach(id => document.querySelector(`[data-face-id="${id}"]`).remove());
            updateToolbar();
        } else {
            alert('Failed to delete faces');
        }
    }

    async function assignFace(faceId) {
        const select = document.getElementById(`assign-select-${faceId}`);
        const personId = select.value;
        if (!personId) return;

        const response = await fetch(`/api/faces/reassign/${faceId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parseInt(personId))
        });

        if (response.ok) {
            document.querySelector(`[data-face-id="${faceId}"]`).remove();
        } else {
            alert('Failed to assign face');
        }
    }

    async function notAFace(faceId) {
        if (!confirm('Delete this face?')) return;

        const response = await fetch(`/api/faces/delete/${faceId}`, { method: 'POST' });
        if (response.ok) {
            document.querySelector(`[data-face-id="${faceId}"]`).remove();
        } else {
            alert('Failed to delete face');
        }
    }

    async function batchNoFaces() {
        const selected = document.querySelectorAll('.face-checkbox:checked');
        if (selected.length === 0) return;

        // Get unique shot IDs from selected faces
        const shotIds = [...new Set(Array.from(selected).map(cb => parseInt(cb.dataset.shotId)))];

        if (!confirm(`Mark ${shotIds.length} shot(s) as "No Faces"? This will remove all face detections from these shots and exclude them from future processing.`)) return;

        const response = await fetch('/shots/exclude-batch-from-face-detection', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ shotIds: shotIds })
        });

        if (response.ok) {
            // Remove all face cards for those shots
            shotIds.forEach(shotId => {
                document.querySelectorAll(`[data-shot-id="${shotId}"]`).forEach(el => el.remove());
            });
            updateToolbar();
        } else {
            alert('Failed to exclude shots');
        }
    }
</script>
