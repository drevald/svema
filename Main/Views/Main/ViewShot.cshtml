@model Form.ShotDTO
@using Newtonsoft.Json
@using System.Web
@{
    Layout = "_Layout";
}

<script>
    function editComment(id, text) {
        document.getElementById("text").value = text;
        document.getElementById("commentId").value = id;
    }
</script>

<script type="text/javascript">
    ymaps.ready(init);

    var jsModel = JSON.parse("@Html.Raw(HttpUtility.JavaScriptStringEncode(JsonConvert.SerializeObject(@Model)))");

    function init() {
        const myMap = new ymaps.Map("map", {
            center: [jsModel.Latitude, jsModel.Longitude],
            zoom: jsModel.Zoom,
            controls: []
        });

        myMap.geoObjects.add(
            new ymaps.GeoObject(
                {
                    geometry: { type: "Point", coordinates: [jsModel.Latitude, jsModel.Longitude] },
                    properties: { iconContent: jsModel.Name }
                },
                {
                    preset: 'islands#blackStretchyIcon',
                    draggable: false
                }
            )
        );
    }
</script>

<div class="container-fluid">
    <div class="row flex-column flex-md-row h-100">
        <!-- PHOTO FIRST ON MOBILE -->
        <div class="col-md-9 col-lg-9 p-4 order-1 order-md-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body photo-view position-relative p-0"
                    style="background-image: url('/shot?id=@Model.ShotId&flip=@Model.Flip&rotate=@Model.Rotate&token=@Model.Token'); background-size: contain; background-repeat: no-repeat; background-position: center;">
                    <canvas id="faceCanvas"
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; cursor: pointer;"></canvas>
                </div>
            </div>
        </div>

        <!-- LEFT COLUMN -->
        <div class="col-md-3 col-lg-3 p-4 border-end order-2 order-md-1">
            <div class="d-flex justify-content-between mb-3">
                <div>
                    <a class="btn btn-secondary btn-sm"
                        href="/view_album?id=@Model.AlbumId&token=@Model.Token">Назад</a>
                    <a class="btn btn-primary btn-sm" href="/edit_shot?id=@Model.ShotId">Ред</a>
                    <a class="btn btn-primary btn-sm" href="/orig?id=@Model.ShotId&token=@Model.Token">Ориг</a>
                    <button type="button" class="btn btn-info btn-sm" id="toggleFacesBtn">Toggle Faces</button>
                    <button type="button" class="btn btn-warning btn-sm" id="noFacesBtn">No Faces</button>
                </div>
                <div>
                    <a class="btn btn-primary btn-sm"
                        href="/view_prev_shot?id=@Model.ShotId&token=@Model.Token">Пред</a>
                    <a class="btn btn-primary btn-sm"
                        href="/view_next_shot?id=@Model.ShotId&token=@Model.Token">След</a>
                </div>
            </div>

            <!-- COLLAPSE BUTTON (mobile only) -->
            <button class="btn btn-outline-secondary w-100 mb-3 d-md-none" type="button" data-bs-toggle="collapse"
                data-bs-target="#detailsPanel">
                Показать / Скрыть детали
            </button>

            <!-- COLLAPSIBLE DETAILS PANEL -->
            <div class="collapse d-md-block" id="detailsPanel">
                <div class="row g-2">
                    <div class="col-4 fw-bold">Альбом</div>
                    <div class="col-8">@Model.AlbumName</div>

                    <div class="col-4 fw-bold">Дата снимка</div>
                    <div class="col-5">@Model.DateStart</div>
                    @if (Model.DateStart != DateTime.MinValue
                    && Model.DateEnd != DateTime.MinValue
                    && Model.DateStart == Model.DateEnd
                    && Model.DateStart != DateTime.MaxValue)
                    {
                        <div class="col-3 fw-bold">
                            <a class="btn btn-primary btn-sm border-end"
                                href="/same_day?month=@Model.DateStart.Month&day=@Model.DateStart.Day">
                                Другие годы
                            </a>
                        </div>
                    }
                    <div class="col-4 fw-bold">Камера</div>
                    <div class="col-8">@Model.CameraManufacturer&nbsp;@Model.CameraModel</div>

                    <div class="col-12 fw-bold mt-2">Место</div>
                    <div class="col-12 mb-3">
                        <div id="map" style="height:240px; border-radius: 10px; overflow:hidden;"></div>
                    </div>

                    <div class="col-12 fw-bold mt-3">Комментарии</div>
                    @if (Model.ShotComments != null)
                    {
                        foreach (var comment in Model.ShotComments)
                        {
                            <div class="col-12 mb-2 border-bottom pb-1">
                                <small>
                                    <b>@comment.AuthorUsername</b>&nbsp;
                                    @comment.Timestamp.ToString("yyyy/MM/dd, HH:mm:ss")<br />
                                    @comment.Text
                                    @if (comment.AuthorUsername == Context.User.Identity.Name)
                                    {
                                        <a href="/delete_shot_comment?commentId=@comment.Id&id=@Model.ShotId">Delete&nbsp;</a>
                                        <a
                                            href="javascript:editComment(@comment.Id, '@HttpUtility.JavaScriptStringEncode(comment.Text)')">Edit&nbsp;</a>
                                    }
                                </small>
                            </div>
                        }
                    }

                    <form action="/add_shot_comment@(string.IsNullOrEmpty(Model.Token) ? "" : "?token=" + Model.Token)" method="post">
                        <input type="hidden" id="id" name="id" value="@Model.ShotId" />
                        <input type="hidden" id="commentId" name="commentId" value="0" />
                        <div class="col-12">
                            <textarea class="form-control mb-3" rows="4" id="text" name="text"></textarea>
                        </div>
                        <div class="col-12">
                            <input class="btn btn-primary btn-sm" value="Set Comment" type="submit" />
                            <input class="btn btn-secondary btn-sm" type="reset" value="Reset" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let facesVisible = false;
    let faceData = null;
    let faceRects = []; // Stores face rectangles for click detection
    const shotId = @Model.ShotId;
    const canvas = document.getElementById('faceCanvas');
    const ctx = canvas.getContext('2d');
    const photoView = document.querySelector('.photo-view');

    // Fetch face detections
    async function loadFaceDetections() {
        if (faceData) return;
        try {
            const response = await fetch(`/api/shots/${shotId}/faces`);
            if (response.ok) {
                faceData = await response.json();
            }
        } catch (error) {
            console.error('Error loading face detections:', error);
        }
    }

    // Draw face rectangles
    // The API already returns coordinates in final display space (EXIF + user rotate/flip applied)
    function drawFaces() {
        if (!faceData || faceData.length === 0) return;

        // imageWidth/imageHeight from API are the final displayed image dimensions
        const imageWidth = faceData[0].imageWidth;
        const imageHeight = faceData[0].imageHeight;

        const containerWidth = photoView.clientWidth;
        const containerHeight = photoView.clientHeight;

        // Calculate scale to fit image in container (same logic as background-size: contain)
        const scale = Math.min(containerWidth / imageWidth, containerHeight / imageHeight);
        const scaledWidth = imageWidth * scale;
        const scaledHeight = imageHeight * scale;

        // Calculate offset to center image (same logic as background-position: center)
        const offsetX = (containerWidth - scaledWidth) / 2;
        const offsetY = (containerHeight - scaledHeight) / 2;

        // Set canvas size to match container
        canvas.width = containerWidth;
        canvas.height = containerHeight;

        // Clear canvas
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Reset face rectangles for click detection
        faceRects = [];

        // Draw each face rectangle (coordinates already in final display space from API)
        faceData.forEach(face => {
            const x = offsetX + (face.x * scale);
            const y = offsetY + (face.y * scale);
            const width = face.width * scale;
            const height = face.height * scale;

            // Store for click detection
            faceRects.push({
                x, y, width, height,
                personId: face.personId,
                personName: face.personName,
                area: width * height
            });

            // Draw rectangle
            ctx.strokeStyle = '#00ff00';
            ctx.lineWidth = 3;
            ctx.strokeRect(x, y, width, height);

            // Draw person name if available
            if (face.personName) {
                ctx.fillStyle = '#00ff00';
                ctx.font = '16px Arial';
                ctx.fillText(face.personName, x, y - 5);
            }
        });
    }

    // Clear canvas
    function clearFaces() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    // Toggle button handler
    document.getElementById('toggleFacesBtn').addEventListener('click', async function () {
        await loadFaceDetections();
        facesVisible = !facesVisible;

        if (facesVisible) {
            drawFaces();
            this.classList.remove('btn-info');
            this.classList.add('btn-success');
        } else {
            clearFaces();
            this.classList.remove('btn-success');
            this.classList.add('btn-info');
        }
    });

    // Redraw on window resize
    window.addEventListener('resize', () => {
        if (facesVisible) {
            drawFaces();
        }
    });

    // Click handler for face rectangles
    canvas.addEventListener('click', (e) => {
        if (!facesVisible || faceRects.length === 0) return;

        const rect = canvas.getBoundingClientRect();
        const clickX = e.clientX - rect.left;
        const clickY = e.clientY - rect.top;

        // Find all faces that contain the click point
        const clickedFaces = faceRects.filter(face =>
            clickX >= face.x && clickX <= face.x + face.width &&
            clickY >= face.y && clickY <= face.y + face.height
        );

        if (clickedFaces.length === 0) return;

        // If overlapping, pick the smallest (top) face
        const topFace = clickedFaces.reduce((smallest, face) =>
            face.area < smallest.area ? face : smallest
        );

        if (topFace.personId) {
            window.location.href = `/person/${topFace.personId}`;
        }
    });

    // Update cursor based on hover over faces
    canvas.addEventListener('mousemove', (e) => {
        if (!facesVisible || faceRects.length === 0) {
            canvas.style.cursor = 'default';
            return;
        }

        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;

        const isOverFace = faceRects.some(face =>
            face.personId &&
            mouseX >= face.x && mouseX <= face.x + face.width &&
            mouseY >= face.y && mouseY <= face.y + face.height
        );

        canvas.style.cursor = isOverFace ? 'pointer' : 'default';
    });

    // No Faces button handler
    document.getElementById('noFacesBtn').addEventListener('click', async function () {
        if (confirm('Mark this shot as "No Faces"? This will remove all face detections and exclude it from future face detection.')) {
            try {
                const response = await fetch(`/shot/${shotId}/exclude-from-face-detection`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    location.reload();
                } else {
                    alert('Failed to mark shot as no faces');
                }
            } catch (error) {
                console.error('Error marking shot as no faces:', error);
                alert('Error marking shot as no faces');
            }
        }
    });
</script>
